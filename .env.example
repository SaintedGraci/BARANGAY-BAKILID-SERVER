# Database Configuration
DB_NAME=barangay_system
DB_USER=root
DB_PASSWORD=your_secure_password_here_change_this
DB_HOST=localhost
DB_DIALECT=mysql

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Secret (CRITICAL: Generate a strong secret with crypto.randomBytes(64).toString('hex'))
# NEVER use default values in production!
# To generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here_MINIMUM_32_CHARACTERS_change_this_in_production

# CORS Configuration (optional)
CORS_ORIGIN=http://localhost:5173

# Rate Limiting (optional - defaults are set in code)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

